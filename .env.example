# =============================================================================
# RedCrossQuest - Docker local environment
# Copy to `.env` and fill in the blanks before running `make up` / `./run.sh`.
# `.env` is git-ignored and .dockerignored; never commit secrets.
# =============================================================================

# ---- Versions (used by Docker build args) ----
PHP_VERSION=8.3
NODE_VERSION=10.24.1
MARIADB_VERSION=11.4

# ---- Host ports (change if already taken) ----
HOST_PORT_API=8080       # Nginx / PHP backend        -> http://localhost:8080/rest
HOST_PORT_FRONT=3000     # gulp serve browser-sync    -> http://localhost:3000
HOST_PORT_FRONT_UI=3001  # gulp serve BS control UI
HOST_PORT_DB=3306        # MariaDB for DBeaver/IntelliJ

# ---- MariaDB ----
MYSQL_ROOT_PASSWORD=CRFCRF
MYSQL_DATABASE=rcq
MYSQL_USER=rcq
MYSQL_PASSWORD=rcq

# ---- PHP runtime ----
PHP_DISPLAY_ERRORS=On
XDEBUG_MODE=debug            # set to `off` to disable step-debugging

# ---- Application env vars (consumed by server/src/settings.sample.php) ----
MYSQL_DSN=mysql:host=mariadb;port=3306;dbname=rcq;charset=utf8mb4
APP_ENV=D                    # D=Dev, T=Test, P=Prod
APP_URL=http://localhost:3000/
JWT_ISSUER=rcq-local
SENDGRID_SENDER=noreply@localhost
REDQUEST_DOMAIN=http://localhost:3000/

# ---- Google Cloud (optional, for Firestore / PubSub / Secret Manager) ----
# Path INSIDE the container. Mount the host file via docker-compose override
# or drop it in ./.cred/gcp-sa.json (auto-mounted).
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp-sa.json
GOOGLE_CLOUD_PROJECT=rcq-fr-dev
