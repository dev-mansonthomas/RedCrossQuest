# =============================================================================
# RedCrossQuest - Docker local environment
# Copy to `.env` and fill in the blanks before running `make up` / `./run.sh`.
# `.env` is git-ignored and .dockerignored; never commit secrets.
# =============================================================================

# ---- Versions (used by Docker build args) ----
PHP_VERSION=8.5
NODE_VERSION=10.24.1

# ---- Host ports (change if already taken) ----
HOST_PORT_API=8080       # Nginx / PHP backend        -> http://localhost:8080/rest
HOST_PORT_FRONT=3000     # gulp serve browser-sync    -> http://localhost:3000
HOST_PORT_FRONT_UI=3001  # gulp serve BS control UI

# ---- PHP runtime ----
PHP_DISPLAY_ERRORS=On
XDEBUG_MODE=debug            # set to `off` to disable step-debugging

# ---- Database ----
# MySQL runs in the external `rcq_mysql` container (dashboard project),
# published on the host at 127.0.0.1:3316. The hostname `rcq` is mapped to
# the host gateway via docker-compose `extra_hosts` so the same DSN value
# works identically on the host and inside the php-fpm container.
MYSQL_DSN=mysql:host=rcq;port=3316;dbname=rcq_fr_dev_db;charset=utf8mb4
MYSQL_USER=rcq-fr-dev-user
# MYSQL_PASSWORD is NEVER set here: it is fetched at runtime from GCP Secret
# Manager (project rcq-fr-dev, secret `local-MYSQL_PASSWORD`) by
# SecretManagerService.

# ---- Application env vars (consumed by server/src/settings.php) ----
APP_ENV=D                    # D=Dev, T=Test, P=Prod
APP_URL=http://localhost:3000/
JWT_ISSUER=rcq-local
SENDGRID_SENDER=noreply@localhost
REDQUEST_DOMAIN=http://localhost:3000/

# ---- Google Cloud (Secret Manager, Firestore, PubSub) ----
# The host directory ~/.cred is mounted read-only at /run/secrets inside the
# php-fpm container (see docker-compose.yml). GOOGLE_APPLICATION_CREDENTIALS
# must point to the service-account JSON path AS SEEN FROM THE CONTAINER.
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/rcq-fr-dev-61e86fa56dc1.json
GOOGLE_CLOUD_PROJECT=rcq-fr-dev
