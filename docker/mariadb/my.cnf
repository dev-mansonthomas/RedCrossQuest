# RedCrossQuest MariaDB config - mirrors the macOS install guide tweaks
# (/usr/local/etc/my.cnf on the host).

[mysqld]
# Same sql_mode as production; keeping ONLY_FULL_GROUP_BY out for Spotfire Analyst
sql_mode = "STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_AUTO_CREATE_USER,NO_ENGINE_SUBSTITUTION"

# Server in UTC; PHP container handles Europe/Paris conversion
default-time-zone='+00:00'

# Case-sensitive table names (Linux-like), matches production on Cloud SQL
lower_case_table_names = 0

character-set-server = utf8mb4
collation-server     = utf8mb4_unicode_ci

max_allowed_packet   = 64M
innodb_buffer_pool_size = 256M

[client]
default-character-set = utf8mb4
