{
    "name": "rcq/redcrossquest",
    "description": "French Red Cross yearly fundraising rest backend",
    "keywords": ["RedCross","CroixRouge","FundRaising"],
    "homepage": "https://github.com/dev-mansonthomas/RedCrossQuest",
    "license": "GPL-3.0-or-later",
    "type": "project",
    "authors": [
        {
            "name": "Thomas Manson",
            "email": "cv@mansonthomas.com",
            "homepage": "http://www.mansonthomas.com/"
        }
    ],
    "require": {
        "php": "^8.5",
        "ext-PDO": "*",
        "ext-bz2": "*",
        "ext-json": "*",
        "ext-sodium": "*",
        "ext-zip": "*",
        "doctrine/annotations": "^1.14.3",
        "egulias/email-validator": "^4.0.4",
        "google/apiclient": "^2.19.2",
        "google/cloud-firestore": "^1.55",
        "google/cloud-logging": "^1.34",
        "google/cloud-pubsub": "^2.19",
        "google/cloud-secret-manager": "^2.3",
        "google/cloud-storage": "^1.51",
        "google/common-protos": "^4.14",
        "google/gax": "^1.42",
        "google/protobuf": "^v5.34.1",
        "google/recaptcha": "^1.4",
        "grpc/grpc": "^1.80",
        "guzzlehttp/guzzle": "^7.9.3",
        "jolicode/slack-php-api": "^v4.8.0",
        "kreait/firebase-php": "^7.18.0",
        "lcobucci/jwt": "^5.6",
        "nesbot/carbon": "^3.9.1",
        "nyholm/psr7": "^1.8.2",
        "php-di/php-di": "^7.1.1",
        "phpmailer/phpmailer": "^v6.10.0",
        "ramsey/uuid": "^4.7.6",
        "robmorgan/phinx": "^0.16.11",
        "sendgrid/sendgrid": "^8.1.11",
        "slim/php-view": "^3.4.0",
        "slim/psr7": "1.7.0",
        "slim/slim": "^4.15.1",
        "symfony/http-client": "^v7.2.4",
        "symfony/validator": "^v7.2.6",
        "zircote/swagger-php": "^4.11.1"
    },
    "autoload": {
      "psr-4": {
          "RedCrossQuest\\": "src/"
      },
        "exclude-from-classmap": [
            "vendor/google/common-protos/metadata/Rpc/Context/AttributeContext.php"
        ]
    },

    "config": {
        "optimize-autoloader": true,
        "classmap-authoritative": true,
        "sort-packages": true,
        "preferred-install": {
            "*": "dist"
        },
        "platform": {
            "php": "8.5",
            "ext-sodium": "8.5"
        },
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "require-dev": {
        "phpcompatibility/php-compatibility": "^9.3",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "squizlabs/php_codesniffer": "^3.11"
    },
    "scripts": {
        "phpstan":         "phpstan analyse --no-progress --memory-limit=1G",
        "phpcs:compat":    "phpcs --standard=phpcs.xml --no-colors",
        "audit:php85":     ["@phpstan", "@phpcs:compat"],
        "post-install-cmd": [
            "vendor/bin/phpcs --config-set installed_paths vendor/phpcompatibility/php-compatibility > /dev/null 2>&1 || true"
        ],
        "post-update-cmd": [
            "vendor/bin/phpcs --config-set installed_paths vendor/phpcompatibility/php-compatibility > /dev/null 2>&1 || true"
        ]
    }
}
