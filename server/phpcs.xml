<?xml version="1.0"?>
<ruleset name="RCQ PHP 8.5 compatibility">
    <description>PHPCompatibility scan targeting PHP 8.5 for the technical_upgrade migration.</description>

    <file>src</file>
    <file>public</file>

    <exclude-pattern>vendor/*</exclude-pattern>
    <exclude-pattern>logs/*</exclude-pattern>
    <exclude-pattern>openapi/*</exclude-pattern>
    <exclude-pattern>db/*</exclude-pattern>

    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="sp"/>

    <rule ref="PHPCompatibility"/>

    <config name="testVersion" value="8.5-"/>
</ruleset>
